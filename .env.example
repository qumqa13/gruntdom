# GRUNTDOM APP — environment variables template
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored — never commit secrets.

# === AI visualization (Replicate) ===
# Token from https://replicate.com/account/api-tokens
# Without this token the app runs in MOCK mode (returns prompts only,
# no real images). Mock mode is useful for UI work and CI.
REPLICATE_API_TOKEN=

# === Public app URL (used to absolutize image URLs sent to Replicate) ===
# In dev: http://localhost:3000 OR your ngrok/cloudflare tunnel URL.
# In prod: your deployed domain (https://gruntdom.example).
# Replicate fetches the base plot photo from this URL — it MUST be
# reachable from the public internet (Replicate's GPUs cannot see localhost).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Optional: rate limiting tuning (Phase C) ===
# Max generations per IP per hour. Default: 10.
# RATE_LIMIT_GENERATIONS_PER_HOUR=10
