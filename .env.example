# GRUNTDOM APP — environment variables template
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored — never commit secrets.

# === AI visualization (Replicate) ===
# Token from https://replicate.com/account/api-tokens
# Without this token the app runs in MOCK mode (returns prompts only,
# no real images). Mock mode is useful for UI work and CI.
REPLICATE_API_TOKEN=

# === Public app URL (used to absolutize image URLs sent to Replicate) ===
# In dev: http://localhost:3000 OR your ngrok/cloudflare tunnel URL.
# In prod: your deployed domain (https://gruntdom.example).
# Replicate fetches the base plot photo from this URL — it MUST be
# reachable from the public internet (Replicate's GPUs cannot see localhost).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Optional: rate limiting tuning (Phase C) ===
# Max generations per IP per hour. Default: 10.
# RATE_LIMIT_GENERATIONS_PER_HOUR=10

# === F2 Cesium terrain — Tier 2 ION (per ADR-0002 §6.3 + ADR-0005) ===
# Tier 2 is the F2 MVP path (Tier 1 cesium-terrain-builder skipped per
# Oskar's F2 kick-off briefing on 2026-05-10).
#
# NEXT_PUBLIC_ prefix is intentional: this is a free-tier domain-restricted
# browser-bearer credential, not a server-bearer secret. ION designs free-tier
# tokens for direct client use — the dashboard pins the token to specific
# domains + assets, so exposure ≠ key compromise. See ADR-0005 for the
# decision record + revisit triggers (paid tier, provider switch, compromise).
#
# Get one from https://cesium.com/ion/tokens (free tier: 5 GB/mc, ~1k tile
# requests/hr — enough for the Balice 773 showcase plot in F2).
#
# Pre-launch: USER-action — restrict the token to *.gruntdom.pl + Vercel
# preview domains in https://cesium.com/ion/tokens before the first public
# deploy. Spike + dev: unrestricted is fine.
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# === F2 Cesium terrain — M2 Polish NMT 1m tiles (per ADR-0006 §M2) ===
# Base URL where M2's quantized-mesh tileset directories live. Cesium probes
# `${BASE}/<tileset>/layer.json` then fetches `${BASE}/<tileset>/{z}/{x}/{y}.terrain`.
#
# Leave empty (default) to serve tiles from `public/terrain-tiles/` as Next.js
# static assets at `/terrain-tiles/<tileset>`. This is the dev path and the
# Phase A.5 pre-Vercel path — tiles are gitignored and produced locally via
# `npm run build-terrain`.
#
# Set to the CDN origin (e.g. `https://terrain.gruntdom.pl`) for production
# once tiles are mirrored to Cloudflare R2 per ADR-0006 §"Architectural
# Implications". No secret material lives at this URL — quantized-mesh is an
# open-data derivative of PZGiK NMT, attribution surfaces in the provenance
# plakietka.
NEXT_PUBLIC_TERRAIN_BASE_URL=
